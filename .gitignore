# Voice reference samples
tts-server/voices/

# Test audio files
tts-server/*.wav
tts-server/*.mp3

# HuggingFace deploy directories (has nested .git)
tts-server/hf-deploy/
tts-server/hf-space/

# Gemini agents data
.agents/skills/*/scripts/__pycache__/
